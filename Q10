//Converter um inteiro informado menor que 32 para sua representacao em binario

#include <stdio.h>

int main()
{
    int num, i;
    
    printf("Insira um numero de 0 a 32 a ser convertido: \n");
    scanf("%d", &num);
    
    if(num < 0 || num > 32){
        printf("Erro, numero fora dos padroes definidos!");
        return 1;
    }else{
        if(num == 0){
            printf("O numero em binario equivale a: 000000");
        }else{
            int vetor[6], temp = num;
        
            for(i = 0; i < 6; i++){
                vetor[i] = temp % 2;
                temp = temp/2;
            }
            for(i; i < 6; i++){
                vetor[i] = 0;
            }
        
            printf("O numero em binario equivale a: ");
            for(int i = 6 - 1; i >= 0; i--){
                printf("%d ", vetor[i]);
            }
        }
    }
    return 0;
}
