//questao 10 adaptada para conversao de decimais de 0 a 255

#include <stdio.h>

int main()
{
    int num, i;
    
    printf("Insira um numero de 0 a 255 a ser convertido: \n");
    scanf("%d", &num);
    
    if(num < 0 || num > 255){
        printf("Erro, numero fora dos padroes definidos!");
        return 1;
    }else{
        if(num == 0){
            printf("O numero em binario equivale a: 000000");
        }else{
            int vetor[8], temp = num;
        
            for(i = 0; i < 8; i++){
                vetor[i] = temp % 2;
                temp = temp/2;
            }
            for(i; i < 8; i++){
                vetor[i] = 0;
            }
        
            printf("O numero em binario equivale a: ");
            for(int i = 8 - 1; i >= 0; i--){
                printf("%d ", vetor[i]);
            }
        }
    }
    return 0;
}
